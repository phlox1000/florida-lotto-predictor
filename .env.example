# Local / deployment environment template (no secrets — copy to `.env` and fill in values).
# See `docs/DEPLOYMENT.md` for Render-specific notes and variable migration.

# --- Required (production) ---
NODE_ENV=development
DATABASE_URL=
JWT_SECRET=

# Manus / OAuth (required for the shipped auth flow)
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# --- LLM & Forge gateway (optional for full AI narrative; app serves data-driven fallbacks if unset) ---
# Preferred names (set these on new deployments):
FORGE_API_URL=
FORGE_API_KEY=

# Legacy aliases (still supported; same semantics as FORGE_API_*)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# Optional: OpenAI-style key alias — used only as a **key** fallback (same effective role as FORGE_API_KEY).
# OPENAI_API_KEY=

# --- Optional infrastructure ---
# Redis (rate limits / multi-instance; see render.yaml)
# REDIS_URL=

# Client-only (Vite): maps / frontend helpers when applicable
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
